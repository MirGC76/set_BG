{
  "rules": {
    "rooms": {
      "$code": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['status','hostId','players'])",

        "status": { ".validate": "newData.isString()" },
        "hostId": { ".validate": "newData.isString()" },
        "activePlayer": { ".validate": "newData.val() === null || newData.isString()" },
        "claimTs": { ".validate": "newData.val() === null || newData.isNumber()" },
        "version": { ".validate": "newData.isNumber()" },

        "players": {
          "$playerId": {
            ".validate": "newData.hasChildren(['name','score'])",
            "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "score": { ".validate": "newData.isNumber()" }
          }
        },

        "deck": { ".validate": "newData.val() === null || true" },
        "board": { ".validate": "newData.val() === null || true" },
        "lastResult": { ".validate": true }
      }
    },

    "blokusRooms": {
      "$code": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['status','hostId','players','playerOrder'])",

        "status": { ".validate": "newData.isString()" },
        "hostId": { ".validate": "newData.isString()" },
        "maxPlayers": { ".validate": "newData.isNumber()" },
        "currentIdx": { ".validate": "newData.isNumber()" },
        "version": { ".validate": "newData.isNumber()" },
        "playerOrder": { ".validate": true },
        "board": { ".validate": true },
        "lastMove": { ".validate": true },

        "players": {
          "$playerId": {
            ".validate": "newData.hasChildren(['name','color'])",
            "name": { ".validate": "newData.isString() && newData.val().length <= 20" },
            "color": { ".validate": "newData.isString()" }
          }
        }
      }
    }
  }
}
